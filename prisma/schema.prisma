generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum HouseholdRole {
  OWNER
  ADMIN
  MEMBER
}

enum OnboardingStep {
  HOUSEHOLD
  PRIMARY_PROFILE
  FAMILY_MEMBERS
  REVIEW
  COMPLETED
}

enum ProfileRelation {
  SELF
  SPOUSE
  SON
  DAUGHTER
  FATHER
  MOTHER
  GRANDPARENT
  OTHER
}

enum ProfileGender {
  MALE
  FEMALE
  NON_BINARY
  OTHER
  PREFER_NOT_TO_SAY
}

enum RecordCategory {
  LAB_RESULT
  PRESCRIPTION
  VACCINATION
  IMAGING
  DISCHARGE_SUMMARY
  BILLING
  INSURANCE
  OTHER
}

model User {
  id                       String          @id @default(cuid())
  firebaseUid              String          @unique
  email                    String          @unique
  displayName              String?
  photoUrl                 String?
  emailVerified            Boolean         @default(false)
  isActive                 Boolean         @default(true)
  onboardingCompleted      Boolean         @default(false)
  onboardingStep           OnboardingStep  @default(HOUSEHOLD)
  onboardingHouseholdName  String?
  onboardingPrimaryProfile Json?
  onboardingFamilyMembers  Json?
  primaryHouseholdId       String?
  lastLoginAt              DateTime?
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt
  householdMemberships     HouseholdMember[]
  createdProfiles          Profile[]       @relation("ProfileCreatedBy")
  linkedProfiles           Profile[]       @relation("ProfileLinkedUser")
  ownedHouseholds          Household[]     @relation("HouseholdOwner")
  primaryHousehold         Household?      @relation("UserPrimaryHousehold", fields: [primaryHouseholdId], references: [id], onDelete: SetNull)

  @@index([primaryHouseholdId])
}

model Household {
  id         String            @id @default(cuid())
  name       String
  timezone   String            @default("UTC")
  ownerId    String
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  members    HouseholdMember[]
  profiles   Profile[]
  owner      User              @relation("HouseholdOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  primaryFor User[]            @relation("UserPrimaryHousehold")

  @@index([createdAt])
  @@index([ownerId])
}

model HouseholdMember {
  id          String        @id @default(cuid())
  householdId String
  userId      String
  role        HouseholdRole @default(MEMBER)
  isDefault   Boolean       @default(false)
  invitedAt   DateTime?
  joinedAt    DateTime      @default(now())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([householdId, userId])
  @@index([userId])
}

model Profile {
  id              String         @id @default(cuid())
  householdId     String
  createdByUserId String
  linkedUserId    String?
  fullName        String
  relation        ProfileRelation
  dateOfBirth     DateTime?
  gender          ProfileGender?
  bloodGroup      String?
  isPrimary       Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  household  Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdBy  User      @relation("ProfileCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  linkedUser User?     @relation("ProfileLinkedUser", fields: [linkedUserId], references: [id], onDelete: SetNull)
  records    Record[]

  @@index([householdId])
  @@index([createdByUserId])
  @@index([linkedUserId])
}

model Record {
  id            String         @id @default(cuid())
  profileId     String
  category      RecordCategory @default(OTHER)
  title         String
  providerName  String?
  recordDate    DateTime?
  notes         String?        @db.Text
  extractedText String?        @db.LongText
  tags          Json?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?

  profile Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  files   RecordFile[]

  @@index([profileId])
  @@index([category])
  @@index([recordDate])
  @@index([deletedAt])
  @@fulltext([title, notes, extractedText])
}

model RecordFile {
  id           String   @id @default(cuid())
  recordId     String
  driveFileId  String
  mimeType     String
  originalName String
  size         Int
  encryptionIv String
  checksum     String
  createdAt    DateTime @default(now())

  record Record @relation(fields: [recordId], references: [id], onDelete: Cascade)

  @@index([recordId])
}
